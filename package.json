{
  "name": "vela",
  "version": "1.0.0",
  "private": true,
  "description": "Vela — vibe-productive word processor with an AI agent",
  "author": "youssef hossam",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -p 3000",
    "db:push": "echo \"(no database — Vela uses localStorage)\"",
    "build:web": "cross-env BUILD_FOR_ELECTRON=1 next build",
    "lint": "eslint .",
    "electron:dev": "cross-env VELA_DEV=1 concurrently -k -n NEXT,ELECTRON -c magenta,cyan \"next dev -p 3000\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "electron-builder",
    "dist": "npm run build:web && npm run build:electron",
    "dist:win": "npm run build:web && electron-builder --win nsis",
    "dist:mac": "npm run build:web && electron-builder --mac dmg zip",
    "dist:linux": "npm run build:web && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "@mdxeditor/editor": "^3.39.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^3.0.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  }
}